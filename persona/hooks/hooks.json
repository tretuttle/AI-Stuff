{
  "SubagentStart": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "jq -r '.agent_type' | xargs -I{} echo \"[persona] Starting review: {}\" >&2"
        }
      ]
    }
  ],
  "SubagentStop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "jq -r '.agent_type' | xargs -I{} echo \"[persona] Finished review: {}\" >&2"
        }
      ]
    }
  ]
}
